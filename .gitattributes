# Keep Linux-run files as LF even when edited/checked out on Windows, so GMK
# shell scripts, ROS2 launch/Python (shebang) and C++ keep working on the GMK box.
*.sh        text eol=lf
*.py        text eol=lf
*.cpp       text eol=lf
*.hpp       text eol=lf
*.h         text eol=lf
*.msg       text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.xml       text eol=lf
*.md        text eol=lf
CMakeLists.txt text eol=lf

# Binary assets git must not touch.
*.png   binary
*.jpg   binary
*.jpeg  binary
